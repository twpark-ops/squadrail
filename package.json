{
  "name": "squadrail-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.mjs dev",
    "dev:watch": "SQUADRAIL_MIGRATION_PROMPT=never node scripts/dev-runner.mjs watch",
    "dev:server": "pnpm --filter @squadrail/server dev",
    "dev:ui": "pnpm --filter @squadrail/ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @squadrail/db generate",
    "db:migrate": "pnpm --filter @squadrail/db migrate",
    "secrets:migrate-inline-env": "tsx scripts/migrate-inline-env-secrets.ts",
    "db:backup": "./scripts/backup-db.sh",
    "squadrail": "node cli/node_modules/tsx/dist/cli.mjs cli/src/index.ts",
    "build:npm": "./scripts/build-npm.sh",
    "release": "./scripts/release.sh",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "check:tokens": "node scripts/check-forbidden-tokens.mjs",
    "docs:dev": "cd docs && npx mintlify dev",
    "smoke:openclaw-join": "./scripts/smoke/openclaw-join.sh",
    "smoke:openclaw-docker-ui": "./scripts/smoke/openclaw-docker-ui.sh",
    "smoke:local-ui-flow": "./scripts/smoke/local-ui-flow.sh",
    "e2e:full-delivery": "node scripts/e2e/full-delivery.mjs",
    "e2e:cloud-swiftsight-real-org": "node scripts/e2e/cloud-swiftsight-real-org.mjs",
    "e2e:cloud-swiftsight-real-org:cleanup": "node scripts/e2e/cloud-swiftsight-real-org-cleanup.mjs",
    "e2e:cloud-swiftsight-real-org:nightly": "node scripts/e2e/nightly-cloud-swiftsight-real-org.mjs",
    "e2e:cloud-swiftsight-rag-readiness": "node scripts/e2e/cloud-swiftsight-rag-readiness.mjs",
    "knowledge:rebuild-graph": "node cli/node_modules/tsx/dist/cli.mjs scripts/knowledge/rebuild-graph.ts",
    "knowledge:rebuild-versions": "node cli/node_modules/tsx/dist/cli.mjs scripts/knowledge/rebuild-versions.ts",
    "knowledge:backfill-personalization": "node cli/node_modules/tsx/dist/cli.mjs scripts/knowledge/backfill-personalization.ts",
    "test:browser-smoke": "./scripts/smoke/local-ui-flow.sh",
    "audit:tenant-rls": "node scripts/audit/tenant-rls.mjs",
    "bench:retrieval-vector": "node scripts/bench/retrieval-vector.mjs",
    "bootstrap:swiftsight-org": "node scripts/bootstrap/generate-swiftsight-org-bundle.mjs",
    "bootstrap:swiftsight-org:canonical": "node scripts/bootstrap/generate-swiftsight-org-bundle.mjs --root /home/taewoong/workspace/cloud-swiftsight --out bootstrap-bundles/cloud-swiftsight --company-name cloud-swiftsight"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4"
}
