DATABASE_URL=postgres://squadrail:squadrail@localhost:5432/squadrail
PORT=3100
SERVE_UI=false

# OpenAI Configuration (Required for knowledge retrieval)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Override embedding model
# SQUADRAIL_KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
# SQUADRAIL_KNOWLEDGE_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
