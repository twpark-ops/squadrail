# ── Database ──
DATABASE_URL=postgres://squadrail:squadrail@localhost:5432/squadrail

# ── Server ──
PORT=3100
SERVE_UI=false

# ── Authentication ──
# Required for authenticated deployment modes.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# ── AI Provider Keys ──
# At least one is required for agent execution.
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ── Deployment ──
# SQUADRAIL_DEPLOYMENT_MODE=local_trusted    # local_trusted | authenticated
# SQUADRAIL_DEPLOYMENT_EXPOSURE=private      # private | public
# SQUADRAIL_ALLOWED_HOSTNAMES=localhost

# ── Knowledge Retrieval (optional overrides) ──
# SQUADRAIL_KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
# SQUADRAIL_KNOWLEDGE_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
