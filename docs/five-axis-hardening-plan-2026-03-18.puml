@startuml
title Five-Axis Hardening Plan

package "UI" {
  [ProjectDetail]
  [IssueDetail]
  [Knowledge]
  [LiveUpdatesProvider]
}

package "Server" {
  [Knowledge Summary]
  [PM Intake]
  [Projection]
}

package "System Validation" {
  [full-delivery.mjs]
  [support smoke]
  [full smoke]
}

[ProjectDetail] --> [PM Intake] : visible subtasks stay aligned
[Knowledge] --> [Knowledge Summary] : accurate feedback/profile metrics
[IssueDetail] --> [Projection] : lazy tab queries only when needed
[LiveUpdatesProvider] --> [IssueDetail] : protocol-aware invalidation
[full-delivery.mjs] --> [PM Intake] : submit quick request
[full-delivery.mjs] --> [Projection] : preview/apply delivery plan
[full-delivery.mjs] --> [support smoke]
[full-delivery.mjs] --> [full smoke]

note right of [full-delivery.mjs]
Canonical path
quick request ->
PM routing ->
delivery issue ->
review ->
close
end note

@enduml
