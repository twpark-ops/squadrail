participant "POST /issues/:id/merge-candidate/recovery" as RecoveryRoute
database "issues" as IssuesTable
database "issue_protocol_state" as ProtocolState
participant "IssueDetail" as IssueDetail
participant "ProtocolActionConsole" as Console
participant "heartbeat" as Heartbeat

Board -> Desk : Click "Reopen with rollback context"
Desk -> RecoveryRoute : POST reopen_with_rollback_context
