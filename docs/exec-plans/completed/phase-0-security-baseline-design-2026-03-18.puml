@startuml
title Phase 0 Security Baseline

skinparam backgroundColor white
skinparam packageStyle rectangle
skinparam shadowing false

package "Current Gaps" {
  rectangle "Hardcoded Auth Secret" as SecretGap
  rectangle "Email Verification Hardcoded Off" as VerifyGap
  rectangle "Unbounded Document Body" as DocGap
  rectangle "Deliverables Route Shape Drift" as DeliverableGap
}

package "Implementation Axes" {
  rectangle "Config / Schema" as ConfigAxis
  rectangle "Better Auth Runtime" as AuthAxis
  rectangle "Documents Route Limit" as DocAxis
  rectangle "Deliverables Route + UI" as DeliverableAxis
}

package "Validation" {
  rectangle "Focused Route / Auth Tests" as FocusedTests
  rectangle "Server / UI Typecheck" as Typecheck
  rectangle "Deliverables / Documents UI Regression" as UiRegression
}

SecretGap --> ConfigAxis
SecretGap --> AuthAxis

VerifyGap --> ConfigAxis
VerifyGap --> AuthAxis

DocGap --> ConfigAxis
DocGap --> DocAxis

DeliverableGap --> DeliverableAxis

ConfigAxis --> FocusedTests
AuthAxis --> FocusedTests
DocAxis --> FocusedTests
DeliverableAxis --> FocusedTests

AuthAxis --> Typecheck
DocAxis --> Typecheck
DeliverableAxis --> Typecheck
DeliverableAxis --> UiRegression

@enduml
